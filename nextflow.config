manifest {
    name        = 'SVcaller'
    description = 'SV/CNV/SMN1-SMN2 pipeline for human WGS'
    version     = '1.0.0'
    nextflowVersion = '>=25.10.0'
}

params {
    input         = null
    tmp_dir       = System.getenv('TMPDIR') ?: '/tmp'  // host tmp dir; container bind + TMPDIR (portable default)
    ref_fasta     = null
    bwa_index     = null    // prefix of the CLASSIC bwa index (.amb/.ann/.bwt/.pac/.sa) that
                            // SvABA's bwa_idx_load_from_disk needs next to ref_fasta.
                            // null → auto-derived from ref_fasta. Only required unless --skip_svaba.
    genome        = 'GRCh38'
    pon           = null
    outdir        = 'results'
    min_depth     = 25
    skip_gridss   = false
    tiered_gridss = false   // run GRIDSS only on Manta non-PASS regions (faster; serial after Manta)
    skip_scramble = false   // skip Scramble MEI calling (saves ~10 min; omits mobile element insertions)
    skip_melt      = false   // skip MELT MEI calling (saves ~8 h; omits ALU/LINE1/SVA/HERVK insertions)
    melt_refs      = null    // path to MELT me_refs/Hg38/ dir; auto-detected from container if null
    tra_window     = 1000    // breakend-proximity window (bp) for cross-caller translocation consensus
    melt_min_reads = 3       // maps to MELT's -sr (split-read support). MELT's own -sr default is 0 (no filter), so 3 is MORE stringent than stock MELT, not less. Set 0 to maximise recall.
    // DEFAULT FLIPPED TO true 2026-07-22. SvABA has never contributed a single
    // variant: modules/jasmine/merge.nf references vcfs[0..4] and NEVER vcfs[5],
    // so its VCF is staged into the merge task dir and ignored. It is also absent
    // from the design spec's SV ensemble (Manta + DELLY + GRIDSS). Running it cost
    // ~4 h/sample at 16 pinned CPUs (process_high) for no output.
    // Set to false ONLY as a deliberate benchmarked experiment, and wire vcfs[5]
    // into vcf_list.txt first or it still does nothing. See docs/reorg-plan-2026-07-21.md §6.
    skip_svaba     = true    // SvABA: staged but never merged — see above before re-enabling
    skip_strling   = false   // skip STRling genome-wide STR expansion caller
    skip_alpha_globin = false // skip M8 alpha-globin (HBA1/HBA2) measurement (~minutes; targeted)
    hba_region     = 'chr16:1-250000'  // window channel 3 scans for alpha-cluster junctions.
                                       // The whole cluster (HBZ..HBA1) sits in chr16:152k-178k;
                                       // the margin catches breakends outside the gene bodies.
    sv_pon         = null    // path to GIAB SV PON BED (recurrent sites in ≥2 GIAB samples)
    eh_catalog    = "${projectDir}/assets/eh_catalog.json"
    giab_truth      = null
    giab_truth_v5q  = null   // GIAB v5.0q GRCh38 stvar truth (2026-03-02; dipcall-based; richer than T2TQ100)
    annotsv_db    = null
    intervals     = null
    utils_container = 'svcaller/utils:1.3'
    auto_cleanup  = false  // set true to delete work dir on successful completion
    max_cpus      = 64
    max_memory    = '120.GB'
    max_time      = '240.h'
}

env {
    TMPDIR = params.tmp_dir
}

executor {
    name   = 'local'
    cpus   = 64
    memory = '120 GB'
}

includeConfig 'conf/base.config'
profiles {
    docker { includeConfig 'conf/docker.config' }
    local  { includeConfig 'conf/local.config'  }
    test   { includeConfig 'conf/test.config'   }
}

// Self-profiling: every run writes a per-task trace + a timeline + an execution
// report to results/pipeline_info/. Before this, per-stage timing had to be
// reconstructed by hand from .exitcode mtimes. `overwrite = true` so `-resume`
// does not fail on a pre-existing file. `realtime`/`%cpu`/`peak_rss` are the
// fields you actually read when hunting the next bottleneck (e.g. FILTER_CHROMS
// showing 8 CPUs allocated, ~100% of one used).
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/report.html"   }
trace    {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    fields    = 'task_id,hash,process,tag,status,exit,attempt,realtime,duration,%cpu,peak_rss,rchar,wchar'
}
dag      { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/dag.html" }

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min( obj, params.max_cpus as int ) }
        catch (all) { return obj }
    }
}
