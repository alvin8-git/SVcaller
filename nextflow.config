manifest {
    name        = 'SVcaller'
    description = 'SV/CNV/SMN1-SMN2 pipeline for human WGS'
    version     = '1.0.0'
    nextflowVersion = '>=25.10.0'
}

params {
    input         = null
    tmp_dir       = System.getenv('TMPDIR') ?: '/tmp'  // host tmp dir; container bind + TMPDIR (portable default)
    ref_fasta     = null
    bwa_index     = null    // prefix of the CLASSIC bwa index (.amb/.ann/.bwt/.pac/.sa) that
                            // SvABA's bwa_idx_load_from_disk needs next to ref_fasta.
                            // null → auto-derived from ref_fasta. Only required unless --skip_svaba.
    genome        = 'GRCh38'
    pon           = null
    outdir        = 'results'
    min_depth     = 25
    skip_gridss   = false
    tiered_gridss = false   // run GRIDSS only on Manta non-PASS regions (faster; serial after Manta)
    skip_scramble = false   // skip Scramble MEI calling (saves ~10 min; omits mobile element insertions)
    skip_melt      = false   // skip MELT MEI calling (saves ~8 h; omits ALU/LINE1/SVA/HERVK insertions)
    melt_refs      = null    // path to MELT me_refs/Hg38/ dir; auto-detected from container if null
    tra_window     = 1000    // breakend-proximity window (bp) for cross-caller translocation consensus
    melt_min_reads = 3       // min split-read support for MELT call (default 5 → 3 for +recall)
    skip_svaba     = false   // skip SvABA local-assembly caller (6th caller; +plain INS/DEL recall)
    skip_strling   = false   // skip STRling genome-wide STR expansion caller
    skip_alpha_globin = false // skip M8 alpha-globin (HBA1/HBA2) measurement (~minutes; targeted)
    hba_region     = 'chr16:1-250000'  // window channel 3 scans for alpha-cluster junctions.
                                       // The whole cluster (HBZ..HBA1) sits in chr16:152k-178k;
                                       // the margin catches breakends outside the gene bodies.
    sv_pon         = null    // path to GIAB SV PON BED (recurrent sites in ≥2 GIAB samples)
    eh_catalog    = "${projectDir}/assets/eh_catalog.json"
    giab_truth      = null
    giab_truth_v5q  = null   // GIAB v5.0q GRCh38 stvar truth (2026-03-02; dipcall-based; richer than T2TQ100)
    annotsv_db    = null
    intervals     = null
    utils_container = 'svcaller/utils:1.2'
    auto_cleanup  = false  // set true to delete work dir on successful completion
    max_cpus      = 64
    max_memory    = '120.GB'
    max_time      = '240.h'
}

env {
    TMPDIR = params.tmp_dir
}

executor {
    name   = 'local'
    cpus   = 64
    memory = '120 GB'
}

includeConfig 'conf/base.config'
profiles {
    docker { includeConfig 'conf/docker.config' }
    local  { includeConfig 'conf/local.config'  }
    test   { includeConfig 'conf/test.config'   }
}

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min( obj, params.max_cpus as int ) }
        catch (all) { return obj }
    }
}
