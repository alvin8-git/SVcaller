# SVcaller — track source only. Shared convention with pgx-suite / poly-suite:
# pipeline outputs, working dirs, large data, and tooling scratch stay on disk
# locally but are never committed. The ONLY committed report is docs/demo/.

# ── Nextflow outputs & working dirs (tens of GB) ─────────────────────────────
results/
results_*/
results_*.nf.log
work/
work_*/
.nextflow/
.nextflow.log*

# ── Input / validation sequencing data (never committed) ─────────────────────
# Input BAMs live in the central store, NOT in this tree:
#   GIAB HG001-HG007  → /data/alvin/ref/GIAB/
#   SMA trio          → /data/alvin/ref/SMA/   (moved out of ValidationBAM/ 2026-07-21)
# The ValidationBAM/ rule is retained only to catch accidental recreation.
ValidationBAM/
minibam/
pytest-of-alvin/

# ── Built panels / large reference artifacts (built or volume-mounted) ───────
pon/
# benchmarks_data/ moved to /data/alvin/ref/benchmarks/<sample>/fastq/ on 2026-07-21;
# rule retained to catch accidental recreation. Benchmarks/ (GIAB truth) still local.
Benchmarks/
benchmarks_data/

# ── Alignment / variant / index binaries anywhere in the tree ────────────────
*.bam
*.bai
*.cram
*.crai
*.sam
*.vcf.gz
*.vcf.gz.tbi
*.tbi
*.sif
*.simg
*.fa
*.fasta
*.fai

# ── Installer / archive blobs (e.g. MELTv2.2.2.tar.gz) ───────────────────────
*.tar.gz
*.tar.zst
*.zip

# ── Vendored web asset blob (present on disk for Docker build / offline HTML) ─
assets/bootstrap.min.css

# ── Tooling state & scratch (machine-local) ──────────────────────────────────
.omc/
.gstack/
nohup.out
*.log
*.tmp

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.DS_Store

# ── Superseded standalone card demo (folded into docs/demo/HG002_report.html) ─
# Untracked and kept on disk; the full demo report replaces it.
docs/cnv_traits_card_demo.html

# ── The committed demo report is an intentional documentation artifact ───────
!docs/demo/
!docs/demo/**

# ── Synthetic test fixtures are source, not data ─────────────────────────────
# tests/fixtures/alpha_junction.bam is ~2 KB of generated reads with a known
# breakpoint (tests/fixtures/make_junction_fixture.py). The *.bam rule above
# would otherwise silently drop it and the channel-3 tests would skip forever.
!tests/fixtures/
!tests/fixtures/**
