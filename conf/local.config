// Local profile: conda-based execution, no Docker required.
// All processes run inside the 'svcaller' conda environment.

conda.enabled  = true
docker.enabled = false

process {
    conda = '/home/alvin/miniconda3/envs/svcaller'

    // Python bin/ scripts need the bin/ dir on PATH
    withName: 'BUILD_HTML_REPORT|CNV_CONSENSUS|CIRCOS_PLOT' {
        conda    = '/home/alvin/miniconda3/envs/svcaller'
        beforeScript = "export PATH=${projectDir}/bin:\$PATH"
    }
}
