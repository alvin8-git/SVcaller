process {
    cpus   = 2
    memory = 8.GB
    time   = 4.h

    withLabel: process_single {
        cpus   = 1
        memory = 6.GB
        time   = 4.h
    }
    withLabel: process_low {
        cpus   = 4
        memory = 12.GB
        time   = 6.h
    }
    withLabel: process_medium {
        cpus   = 8
        memory = 36.GB
        time   = 12.h
    }
    withLabel: process_high {
        cpus   = 16
        memory = 72.GB
        time   = 24.h
    }
    withLabel: process_gridss {
        cpus   = 8
        memory = 32.GB
        time   = 24.h
    }
}
