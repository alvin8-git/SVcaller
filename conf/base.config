process {
    cpus   = { check_max( 2    * task.attempt, 'cpus'   ) }
    memory = { check_max( 8.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h  * task.attempt, 'time'   ) }

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2

    withLabel: process_single {
        cpus   = { check_max( 1                  , 'cpus'   ) }
        memory = { check_max( 6.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_low {
        cpus   = { check_max( 4     * task.attempt, 'cpus'   ) }
        memory = { check_max( 12.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h   * task.attempt, 'time'   ) }
    }
    withLabel: process_medium {
        cpus   = { check_max( 8     * task.attempt, 'cpus'   ) }
        memory = { check_max( 36.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_high {
        cpus   = { check_max( 16    * task.attempt, 'cpus'   ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time   = { check_max( 24.h  * task.attempt, 'time'   ) }
    }
    withName: 'SAMTOOLS_FILTER_CHROMS' {
        cpus   = { check_max( 8,                     'cpus'   ) }
        memory = { check_max( 8.GB  * task.attempt,  'memory' ) }
        time   = { check_max( 24.h  * task.attempt,  'time'   ) }
    }
    withName: 'BWAMEM2_ALIGN' {
        cpus   = { check_max( 16,                    'cpus'   ) }
        memory = { check_max( 24.GB * task.attempt,  'memory' ) }
        time   = { check_max( 24.h  * task.attempt,  'time'   ) }
    }
    withName: 'PICARD_MARKDUP' {
        cpus   = { check_max( 4,                     'cpus'   ) }
        memory = { check_max( 16.GB * task.attempt,  'memory' ) }
        time   = { check_max( 12.h  * task.attempt,  'time'   ) }
    }
    withName: 'GATK_COLLECT_COUNTS' {
        cpus   = { check_max( 4,                    'cpus'   ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
    }
    withName: 'MANTA_CALL' {
        cpus   = { check_max( 16,                    'cpus'   ) }
        memory = { check_max( 32.GB * task.attempt,  'memory' ) }
        time   = { check_max( 24.h  * task.attempt,  'time'   ) }
    }
    withName: 'DELLY_CALL_SVTYPE' {
        // `delly call` is effectively single-threaded (it parallelises across SV
        // TYPES via 5 separate tasks, not across threads within a task), yet it
        // inherits process_medium's cpus=8. On a 64-core host that made the 5
        // DELLY tasks + Manta(16) + Scramble(8) + CNV callers reserve ~88 cpus,
        // forcing DELLY's svtype fan-out to queue serially (~62 min instead of
        // ~26). Pin to 2 cpus (1 worker + headroom) so all 5 run concurrently.
        // Reservation-only change: `delly call` gets no thread flag here, so the
        // VCFs it emits are byte-for-byte unchanged — this only frees scheduler
        // slots. Do NOT move this onto process_medium: sort/markdup/gcnv/scramble
        // etc. share that label and are genuinely multi-threaded.
        cpus   = { check_max( 2, 'cpus' ) }
    }
    withLabel: process_gridss {
        cpus   = { check_max( 16                 , 'cpus'   ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time   = { check_max( 24.h  * task.attempt, 'time'   ) }
    }
    withName: 'GRIDSS_CALL' {
        // 3 retries: 32 → 64 → 96 GB. GRIDSS is most likely to silent-OOM.
        // For HPC/SLURM deployments add: scratch = true
        maxRetries = 3
    }
    withName: 'SVABA_CALL' {
        // SVABA is memory-bound; fix CPUs so retry doesn't claim 32 slots.
        cpus = { check_max( 16, 'cpus' ) }
    }
}
