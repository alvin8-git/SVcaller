docker.enabled      = true
docker.runOptions   = '--rm -v /data/alvin/tmp:/tmp'

process {
    withName: 'BWAMEM2_ALIGN'         { container = 'quay.io/biocontainers/bwa-mem2:2.2.1--he70b90d_8' }
    withName: 'SAMTOOLS_SORT|SAMTOOLS_FLAGSTAT|SAMTOOLS_FILTER_CHROMS|SAMTOOLS_SUBSET|MANTA_RESIDUAL_REGIONS' { container = 'quay.io/biocontainers/samtools:1.23.1--ha83d96e_0' }
    withName: 'PICARD_MARKDUP|PICARD_INSERT_SIZE' { container = 'quay.io/biocontainers/picard:3.2.0--hdfd78af_0' }
    withName: 'MOSDEPTH'              { container = 'quay.io/biocontainers/mosdepth:0.3.14--h05c3d44_0' }
    withName: 'FASTQC'                { container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0' }
    withName: 'MULTIQC'               { container = 'quay.io/biocontainers/multiqc:1.34--pyhdfd78af_0' }
    withName: 'MANTA_CALL'            { container = 'quay.io/biocontainers/manta:1.6.0--py27h9948957_6' }
    withName: 'DELLY_CALL_SVTYPE'     { container = 'quay.io/biocontainers/delly:1.2.6--hdcf5f25_4' }
    withName: 'DELLY_MERGE'           { container = 'broadinstitute/gatk:4.5.0.0' }
    withName: 'GRIDSS_SETUP|GRIDSS_CALL' { container = 'gridss/gridss:2.13.2' }
    withName: 'GRIDSS_STUB'           { container = 'quay.io/biocontainers/htslib:1.21--h5efdd21_0' }
    withName: 'SCRAMBLE_CALL'         { container = 'quay.io/biocontainers/scramble:1.0.2--h031d066_1' }
    withName: 'SCRAMBLE_STUB'         { container = 'quay.io/biocontainers/htslib:1.21--h5efdd21_0' }
    withName: 'MELT_CALL'            { container = 'svcaller/melt:2.2.2' }
    withName: 'MELT_STUB'            { container = 'quay.io/biocontainers/htslib:1.21--h5efdd21_0' }
    withName: 'EXPANSIONHUNTER'       { container = 'quay.io/biocontainers/expansionhunter:5.0.0--hc26b3af_5' }
    withName: 'STRLING_CALL'          { container = 'quay.io/biocontainers/strling:0.5.2--py39h3e45d22_2' }
    withName: 'SVABA_CALL'            { container = 'quay.io/biocontainers/svaba:1.1.3--h7d875b9_2' }
    withName: 'SVABA_STUB'            { container = 'quay.io/biocontainers/htslib:1.21--h5efdd21_0' }
    withName: 'JASMINE_MERGE'         { container = 'quay.io/biocontainers/jasminesv:1.1.5--hdfd78af_0' }
    withName: 'SURVIVOR_MERGE'        { container = 'quay.io/biocontainers/survivor:1.0.7--hd03093a_2' }
    withName: 'SV_PON_ANNOTATE'       { container = 'quay.io/biocontainers/bedtools:2.31.1--hf5e1c6e_2' }
    withName: 'CNVPYTOR_CALL'         { container = 'quay.io/biocontainers/cnvpytor:1.3.1--pyhdfd78af_1' }
    withName: 'GATK_PREPROCESS_INTERVALS|GATK_COLLECT_COUNTS|GATK_ANNOTATE_INTERVALS|GATK_CREATE_PON|GATK_GCNV_CALL' {
                                        container = 'broadinstitute/gatk:4.5.0.0' }
    withName: 'SMN_CALLER'            { container = 'svcaller/smncopynum:1.1' }
    withName: 'ANNOTSV|GNOMAD_SV_FILTER' { container = 'quay.io/biocontainers/annotsv:3.4.6--py313hdfd78af_0' }
    withName: 'TRUVARI_BENCH'         { container = 'quay.io/biocontainers/truvari:4.3.1--pyhdfd78af_0' }
    withName: 'BUILD_HTML_REPORT|CNV_CONSENSUS|CIRCOS_PLOT' {
                                        container = 'svcaller/utils:1.1' }
}
